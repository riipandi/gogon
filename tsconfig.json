{
    "compilerOptions": {
        "allowImportingTsExtensions": true,
        "jsx": "react-jsx",
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedSideEffectImports": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022",
        "types": [
            "vite/client"
        ],
        "verbatimModuleSyntax": true,
        "baseUrl": ".",
        "paths": {
            "#/*": [
                "./app/*"
            ]
        },
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
}
