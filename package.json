{
    "name": "myapp",
    "version": "0.0.0",
    "private": true,
    "homepage": "https://github.com/riipandi/gogon#readme",
    "bugs": {
        "url": "https://github.com/riipandi/gogon/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/riipandi/gogon.git"
    },
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "cmd": "go run -tags debug .",
        "start": "kill-port 3000 && ./build/release/$npm_package_name serve --port 3000",
        "docker:build": "pnpm --silent run docker-build -t $npm_package_config_image:latest-dev -t $npm_package_config_image:$npm_package_version-dev",
        "docker:push": "docker push $npm_package_config_image:latest-dev && docker push $npm_package_config_image:$npm_package_version-dev",
        "docker:run": "pnpm --silent run docker-run --name $npm_package_name $npm_package_config_image:$npm_package_version-dev",
        "docker:shell": "pnpm --silent run docker-run --entrypoint sh $npm_package_config_image:$npm_package_version-dev",
        "docker:prune": "docker image rm --force $(docker image list --filter reference=$npm_package_config_image:* -q)",
        "docker:images": "docker image list --filter reference=$npm_package_config_image:*",
        "docker-build": "docker build -f ./deploy/Dockerfile . --build-arg DISTROLESS_TAG=debug-nonroot",
        "docker-run": "docker run --network=host --rm -it --env-file=.env -v $(pwd)/storage:/srv/storage",
        "compose:up": "docker compose -f compose.yaml up --detach --remove-orphans",
        "compose:down": "docker compose -f compose.yaml down --remove-orphans",
        "compose:cleanup": "docker compose -f compose.yaml down --remove-orphans --volumes",
        "compose:restart": "pnpm --silent run compose:down && pnpm --silent run compose:up",
        "update-deps": "npm-check-updates --configFileName .ncurc.json",
        "cleanup": "pnpm --silent cleanup:dist && pnpm --silent cleanup:deps",
        "cleanup:dist": "pnpm dlx del-cli .{tanstack,wrangler} build web/dist storybook-static",
        "cleanup:deps": "pnpm dlx del-cli pnpm-lock.yaml node_modules vendor",
        "generate:key": "openssl rand -base64 500 | tr -dc 'a-zA-Z0-9' | fold -w 64 | head -n 1",
        "generate:proto": "buf lint && buf generate --config buf.yaml",
        "postinstall": "go mod download && go mod tidy",
        "test:go": "go test -v ./...",
        "test:ui": "vitest run",
        "format": "pnpm --silent format:go && pnpm --silent format:js",
        "check": "pnpm --silent check:go && pnpm --silent check:js",
        "lint": "pnpm --silent lint:go && pnpm --silent lint:js",
        "format:go": "gofmt -w .",
        "format:js": "oxfmt --write .",
        "check:go": "go vet .",
        "check:js": "oxfmt --check",
        "lint:go": "golangci-lint run -c golangci.yml ./...",
        "lint:js": "oxlint --fix .",
        "typecheck": "tsc -b --noEmit"
    },
    "dependencies": {
        "@connectrpc/connect": "^2.1.1",
        "@connectrpc/connect-query": "^2.2.0",
        "@connectrpc/connect-web": "^2.1.1",
        "@tanstack/react-query": "^5.95.2",
        "@tanstack/react-router": "^1.168.7",
        "lucide-react": "^1.7.0",
        "ofetch": "^1.5.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@bufbuild/protobuf": "^2.11.0",
        "@bufbuild/protoc-gen-es": "^2.11.0",
        "@connectrpc/protoc-gen-connect-query": "^2.2.0",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/devtools-vite": "^0.6.0",
        "@tanstack/react-devtools": "^0.10.0",
        "@tanstack/react-router-devtools": "^1.166.11",
        "@tanstack/router-plugin": "^1.167.8",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "jsdom": "^29.0.1",
        "kill-port-process-cli": "^1.0.16",
        "npm-check-updates": "^19.6.6",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.57.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
        "vitest": "^4.1.2"
    },
    "config": {
        "image": "ghcr.io/riipandi/gogon"
    },
    "engines": {
        "node": ">=24.12.0"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "lightningcss"
        ]
    }
}
