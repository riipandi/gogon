{
    "name": "gogon",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "start": "kill-port 3000 && ./build/release/gogon serve --port 3000",
        "update-deps": "npm-check-updates --configFileName .ncurc.json",
        "gogon": "go run -tags debug .",
        "test": "vitest run"
    },
    "dependencies": {
        "@tanstack/react-router": "latest",
        "lucide-react": "^1.7.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.2"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/devtools-vite": "latest",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/router-plugin": "^1.167.8",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "jsdom": "^29.0.1",
        "kill-port-process-cli": "^1.0.16",
        "npm-check-updates": "^19.6.6",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
