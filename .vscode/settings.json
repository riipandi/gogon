{
    "biome.enabled": false,
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
        "source.fixAll.oxc": "always"
    },
    "files.associations": {
        "*.css": "tailwindcss",
        "*.vars": "dotenv",
        "*.yaml.example": "yaml",
        "*.yml.example": "yaml",
        "wrangler.json": "jsonc"
    },
    "files.readonlyInclude": {
        "**/routeTree.gen.ts": true,
        "**/routes.gen.ts": true
    },
    "files.watcherExclude": {
        "**/routeTree.gen.ts": true,
        "**/routes.gen.ts": true
    },
    "search.exclude": {
        "**/.output": true,
        "**/routeTree.gen.ts": true,
        "**/routes.gen.ts": true
    },
    "go.toolsEnvVars": {
        "GOFLAGS": "-tags=release,debug",
        "GOEXPERIMENT": "jsonv2"
    },
    "gopls": {
        "buildFlags": ["-tags=release,debug"]
    },
    "go.formatTool": "gofmt",
    "go.lintTool": "golangci-lint",
    "go.lintOnSave": "package",
    "tailwindCSS.experimental.classRegex": [
        // @ref: https://www.tailwind-variants.org/docs/getting-started
        // @ref: https://github.com/paolotiu/tailwind-intellisense-regex-list
        ["(?:cn|cx|cva|clx|tv)\\(([^;]*)[\\);]", "[`'\"`]([^'\"`;]*)[`'\"`]"],
        ["classList={{([^;]*)}}", "\\s*?[\"'`]([^\"'`]*).*?:"]
    ],
    "tailwindCSS.files.exclude": ["*.{json,md,mdx,js,ts,yml,yaml}"],
    "[css]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "docker.docker"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced"
    },
    "[go]": {
        "editor.inlayHints.enabled": "onUnlessPressed",
        "editor.defaultFormatter": "golang.go",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "never"
        }
    },
    "[html]": {
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.tabSize": 4
    },
    "[javascript]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports.biome": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    },
    "[javascriptreact]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports.biome": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[markdown]": {
        "editor.defaultFormatter": "darkriszty.markdown-table-prettify"
    },
    "[tailwindcss]": {
        "editor.defaultFormatter": "oxc.oxc-vscode"
    },
    "[toml]": {
        "editor.defaultFormatter": "Shellomo.enhanced-toml",
        "editor.formatOnSave": false
    },
    "[typescript]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports.biome": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    },
    "[typescriptreact]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports.biome": "explicit"
        },
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnPaste": true,
        "editor.formatOnSave": true
    }
}
